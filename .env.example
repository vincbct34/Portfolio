# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Where contact-form submissions are delivered.
CONTACT_TO=vincent260705@gmail.com

# Sender. Requires the domain to be verified in Resend (DKIM/SPF DNS records
# on OVH) — no mailbox needed. Until verified, leave as the test sender below,
# which only delivers to your own Resend account email.
CONTACT_FROM=onboarding@resend.dev
# CONTACT_FROM=Portfolio <contact@vincent-bichat.fr>

# Port the server listens on (Railway sets PORT automatically).
PORT=3001
